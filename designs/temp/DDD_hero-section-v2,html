<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Diamond District Dental NYC | Midtown Manhattan Premier Dentist</title>
    <meta name="description"
        content="Top-rated cosmetic & implant dentist in Midtown NYC. NYU-trained Dr. Oleg Klempner offers veneers, dental implants, LANAP laser gum therapy & same-day consultations." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
        href="https://fonts.googleapis.com/css2?family=Noto+Serif:ital,wght@0,400;0,700;1,400&family=Manrope:wght@300;400;500;600;700;800&display=swap"
        rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link
        href="https://fonts.googleapis.com/css2?family=Noto+Serif:wght@400;700&amp;family=Manrope:wght@300;400;500;600;700;800&amp;display=swap"
        rel="stylesheet" />
    <link
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
        rel="stylesheet" />
    <link
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
        rel="stylesheet" />
    <style>
        /* ── Reset & Base ──────────────────────────────────────────── */
        *,
        *::before,
        *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            font-family: 'Manrope', sans-serif;
            background: #06151f;
            color: #fff;
            overflow-x: hidden;
            -webkit-font-smoothing: antialiased;
        }

        /* ── Color Tokens ─────────────────────────────────────────── */
        :root {
            --navy-deep: #04111a;
            --navy-dark: #071e29;
            --navy-mid: #0b2a3a;
            --navy-nav: #0f3448;
            --teal: #1e7a8a;
            --teal-light: #7ec8d8;
            --teal-glow: rgba(30, 122, 138, 0.25);
            --gold: #f5c842;
            --text-dim: rgba(255, 255, 255, 0.55);
            --text-mid: rgba(255, 255, 255, 0.75);
            --border-sub: rgba(126, 200, 216, 0.12);
            --border-faint: rgba(255, 255, 255, 0.08);
        }

        /* ── Animated Unique Background ───────────────────────────── */
        .page-bg {
            position: fixed;
            inset: 0;
            z-index: 0;
            /* Layered: radial glow + diagonal gradient */
            background:
                radial-gradient(ellipse 80% 60% at 70% 50%, rgba(30, 122, 138, 0.13) 0%, transparent 60%),
                radial-gradient(ellipse 50% 70% at 10% 90%, rgba(0, 55, 108, 0.25) 0%, transparent 55%),
                linear-gradient(145deg, #04111a 0%, #071e29 40%, #0b2a3a 70%, #071e29 100%);
            /* Subtle animated shimmer */
            animation: bgShimmer 14s ease-in-out infinite alternate;
        }

        @keyframes bgShimmer {
            0% {
                background-position: 0% 50%;
            }

            100% {
                background-position: 100% 50%;
            }
        }

        /* ── Diamond Grid Overlay ─────────────────────────────────── */
        .bg-grid {
            position: fixed;
            inset: 0;
            z-index: 0;
            background-image:
                linear-gradient(rgba(126, 200, 216, 0.03) 1px, transparent 1px),
                linear-gradient(90deg, rgba(126, 200, 216, 0.03) 1px, transparent 1px);
            background-size: 60px 60px;
            pointer-events: none;
        }

        /* ── Floating Orbs ────────────────────────────────────────── */
        .orb {
            position: fixed;
            border-radius: 50%;
            filter: blur(80px);
            pointer-events: none;
            z-index: 0;
            animation: orbFloat 18s ease-in-out infinite;
        }

        .orb-1 {
            width: 420px;
            height: 420px;
            background: rgba(30, 122, 138, 0.12);
            top: -100px;
            right: 5%;
            animation-delay: 0s;
        }

        .orb-2 {
            width: 320px;
            height: 320px;
            background: rgba(0, 55, 108, 0.18);
            bottom: 10%;
            left: -80px;
            animation-delay: -7s;
        }

        .orb-3 {
            width: 200px;
            height: 200px;
            background: rgba(126, 200, 216, 0.07);
            top: 45%;
            right: 30%;
            animation-delay: -13s;
        }

        @keyframes orbFloat {

            0%,
            100% {
                transform: translate(0, 0) scale(1);
            }

            33% {
                transform: translate(20px, -30px) scale(1.05);
            }

            66% {
                transform: translate(-15px, 20px) scale(0.95);
            }
        }

        /* ── Top Info Bar ─────────────────────────────────────────── */
        .top-bar {
            position: relative;
            z-index: 50;
            background: var(--navy-deep);
            border-bottom: 0.5px solid var(--border-sub);
            padding: 7px 32px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 8px;
        }

        .top-bar-left {
            font-size: 11.5px;
            color: var(--teal-light);
            letter-spacing: 0.03em;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .top-bar-right {
            display: flex;
            gap: 20px;
            align-items: center;
        }

        .top-bar-phone {
            font-size: 12px;
            color: var(--text-mid);
        }

        .top-bar-phone strong {
            color: #fff;
            font-weight: 600;
        }

        .top-bar-socials {
            display: flex;
            gap: 8px;
            align-items: center;
        }

        .social-dot {
            width: 22px;
            height: 22px;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.08);
            border: 0.5px solid var(--border-sub);
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: background 0.2s;
        }

        .social-dot:hover {
            background: var(--teal-glow);
        }

        .social-dot svg {
            width: 10px;
            height: 10px;
            fill: var(--teal-light);
        }

        /* ── Navigation ───────────────────────────────────────────── */
        nav {
            position: relative;
            z-index: 50;
            background: rgba(15, 52, 72, 0.85);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border-bottom: 0.5px solid rgba(126, 200, 216, 0.15);
            padding: 14px 32px;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .logo-block {
            display: flex;
            align-items: center;
            gap: 12px;
            text-decoration: none;
        }

        .logo-diamond {
            width: 38px;
            height: 38px;
            flex-shrink: 0;
        }

        .logo-text {
            line-height: 1.25;
        }

        .logo-text .l1 {
            font-size: 13px;
            font-weight: 600;
            color: var(--teal-light);
            letter-spacing: 0.07em;
            text-transform: uppercase;
        }

        .logo-text .l2 {
            font-size: 10px;
            color: rgba(255, 255, 255, 0.4);
            letter-spacing: 0.12em;
            text-transform: uppercase;
        }

        .nav-links {
            display: flex;
            gap: 28px;
            list-style: none;
        }

        .nav-links li a {
            font-size: 12px;
            color: rgba(255, 255, 255, 0.65);
            text-decoration: none;
            letter-spacing: 0.03em;
            transition: color 0.2s;
            position: relative;
            padding-bottom: 2px;
        }

        .nav-links li a::after {
            content: '';
            position: absolute;
            bottom: -1px;
            left: 0;
            right: 0;
            height: 1px;
            background: var(--teal-light);
            transform: scaleX(0);
            transition: transform 0.25s ease;
        }

        .nav-links li a:hover {
            color: var(--teal-light);
        }

        .nav-links li a:hover::after {
            transform: scaleX(1);
        }

        .nav-cta {
            background: var(--teal);
            color: #fff;
            font-size: 12.5px;
            font-weight: 600;
            padding: 9px 20px;
            border-radius: 8px;
            border: none;
            cursor: pointer;
            letter-spacing: 0.03em;
            transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
            box-shadow: 0 0 0 0 rgba(30, 122, 138, 0);
        }

        .nav-cta:hover {
            background: #25909e;
            transform: translateY(-1px);
            box-shadow: 0 6px 24px rgba(30, 122, 138, 0.35);
        }

        /* ── Hero Section ─────────────────────────────────────────── */
        .hero-section {
            position: relative;
            z-index: 10;
            min-height: calc(100vh - 88px);
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        /* Full-bleed background image */
        .hero-bg {
            position: absolute;
            inset: 0;
            z-index: 0;
        }

        .hero-bg img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            object-position: 65% center;
            transform: scale(1.06);
            animation: heroZoom 22s ease-in-out infinite alternate;
            display: block;
        }

        @keyframes heroZoom {
            0% {
                transform: scale(1.06);
            }

            100% {
                transform: scale(1.12);
            }
        }

        /* Multi-layer cinematic overlay */
        .hero-overlay {
            position: absolute;
            inset: 0;
            z-index: 1;
            background:
                linear-gradient(105deg, rgba(4, 17, 26, 0.97) 0%, rgba(4, 17, 26, 0.82) 38%, rgba(4, 17, 26, 0.35) 62%, transparent 82%),
                linear-gradient(to top, rgba(4, 17, 26, 0.9) 0%, transparent 40%),
                radial-gradient(ellipse 55% 70% at 78% 35%, rgba(30, 122, 138, 0.22), transparent 65%);
        }

        /* Scanline texture for depth */
        .hero-overlay::after {
            content: '';
            position: absolute;
            inset: 0;
            background-image: repeating-linear-gradient(0deg,
                    transparent,
                    transparent 2px,
                    rgba(0, 0, 0, 0.03) 2px,
                    rgba(0, 0, 0, 0.03) 4px);
            pointer-events: none;
        }

        /* Main content wrapper */
        .hero-content {
            position: relative;
            z-index: 5;
            flex: 1;
            display: grid;
            grid-template-columns: 1fr 1fr;
            align-items: center;
            padding: 64px 68px 80px 68px;
            max-width: 1400px;
            width: 100%;
            margin: 0 auto;
        }

        /* ── LEFT PANEL ───────────────────────────────────────────── */
        .hero-left {
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        /* ── Hero Entrance Animations ─────────────────────────────── */
        @keyframes fadeUp {
            from {
                opacity: 0;
                transform: translateY(28px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
            }

            to {
                opacity: 1;
            }
        }

        @keyframes pulseGlow {

            0%,
            100% {
                box-shadow: 0 0 0 0 rgba(30, 122, 138, 0.4);
            }

            50% {
                box-shadow: 0 0 0 8px rgba(30, 122, 138, 0);
            }
        }

        .hero-anim-1 {
            animation: fadeUp 0.7s cubic-bezier(0.22, 1, 0.36, 1) 0.1s both;
        }

        .hero-anim-2 {
            animation: fadeUp 0.7s cubic-bezier(0.22, 1, 0.36, 1) 0.25s both;
        }

        .hero-anim-3 {
            animation: fadeUp 0.7s cubic-bezier(0.22, 1, 0.36, 1) 0.40s both;
        }

        .hero-anim-4 {
            animation: fadeUp 0.7s cubic-bezier(0.22, 1, 0.36, 1) 0.55s both;
        }

        .hero-anim-5 {
            animation: fadeUp 0.7s cubic-bezier(0.22, 1, 0.36, 1) 0.70s both;
        }

        .hero-anim-6 {
            animation: fadeUp 0.7s cubic-bezier(0.22, 1, 0.36, 1) 0.85s both;
        }

        /* Eyebrow badge */
        .hero-eyebrow {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 22px;
        }

        .eyebrow-pulse {
            width: 7px;
            height: 7px;
            border-radius: 50%;
            background: var(--teal);
            flex-shrink: 0;
            animation: pulseGlow 2.2s ease-in-out infinite;
        }

        .eyebrow-badge {
            background: rgba(30, 122, 138, 0.18);
            border: 1px solid rgba(126, 200, 216, 0.45);
            color: var(--teal-light);
            font-size: 10.5px;
            font-weight: 700;
            padding: 5px 14px;
            border-radius: 20px;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            backdrop-filter: blur(8px);
        }

        /* Headline */
        .hero-h1 {
            font-family: 'Noto Serif', serif;
            font-size: clamp(36px, 4vw, 58px);
            font-weight: 700;
            color: #fff;
            line-height: 1.12;
            margin-bottom: 12px;
            letter-spacing: -0.025em;
        }

        .hero-h1 em {
            font-style: normal;
            background: linear-gradient(135deg, #7ec8d8 0%, #25d0c7 55%, #7ec8d8 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .hero-h1-sub {
            font-family: 'Noto Serif', serif;
            font-size: clamp(15px, 1.6vw, 20px);
            font-weight: 400;
            font-style: italic;
            color: rgba(255, 255, 255, 0.42);
            margin-bottom: 24px;
            letter-spacing: -0.01em;
        }

        /* Descriptor */
        .hero-desc {
            font-size: 14.5px;
            color: rgba(255, 255, 255, 0.62);
            line-height: 1.75;
            margin-bottom: 32px;
            max-width: 440px;
        }

        .hero-desc strong {
            color: rgba(255, 255, 255, 0.9);
            font-weight: 600;
        }

        /* Trust checkmarks */
        .trust-checks {
            display: flex;
            flex-direction: column;
            gap: 11px;
            margin-bottom: 34px;
        }

        .trust-check {
            display: flex;
            align-items: center;
            gap: 11px;
            font-size: 13.5px;
            font-weight: 500;
            color: rgba(255, 255, 255, 0.85);
        }

        .check-icon {
            width: 22px;
            height: 22px;
            border-radius: 50%;
            background: rgba(30, 122, 138, 0.28);
            border: 1px solid rgba(126, 200, 216, 0.55);
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

        .check-icon svg {
            width: 10px;
            height: 10px;
            stroke: var(--teal-light);
            stroke-width: 2.5;
            fill: none;
            stroke-linecap: round;
            stroke-linejoin: round;
        }

        /* CTAs */
        .hero-ctas {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
            margin-bottom: 36px;
            align-items: center;
        }

        .btn-primary {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: linear-gradient(135deg, #1b7282 0%, #239aad 100%);
            color: #fff;
            font-size: 13.5px;
            font-weight: 700;
            padding: 14px 28px;
            border-radius: 10px;
            border: none;
            cursor: pointer;
            letter-spacing: 0.04em;
            box-shadow: 0 10px 32px rgba(30, 122, 138, 0.45), 0 2px 0 rgba(255, 255, 255, 0.06) inset;
            transition: transform 0.22s, box-shadow 0.22s;
            text-decoration: none;
            white-space: nowrap;
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 16px 42px rgba(30, 122, 138, 0.6);
        }

        .btn-primary svg {
            width: 15px;
            height: 15px;
            stroke: #fff;
            stroke-width: 2.2;
            fill: none;
            flex-shrink: 0;
        }

        .btn-phone {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: rgba(255, 255, 255, 0.06);
            color: rgba(255, 255, 255, 0.82);
            font-size: 13.5px;
            font-weight: 600;
            padding: 14px 24px;
            border-radius: 10px;
            border: 1px solid rgba(255, 255, 255, 0.16);
            cursor: pointer;
            letter-spacing: 0.02em;
            transition: background 0.22s, border-color 0.22s, color 0.22s;
            text-decoration: none;
            backdrop-filter: blur(8px);
            white-space: nowrap;
        }

        .btn-phone:hover {
            background: rgba(255, 255, 255, 0.12);
            border-color: rgba(126, 200, 216, 0.45);
            color: #fff;
        }

        .btn-phone svg {
            width: 14px;
            height: 14px;
            stroke: var(--teal-light);
            stroke-width: 2;
            fill: none;
            flex-shrink: 0;
        }

        .btn-secondary {
            background: rgba(255, 255, 255, 0.05);
            color: rgba(255, 255, 255, 0.8);
            font-size: 13.5px;
            font-weight: 500;
            padding: 14px 26px;
            border-radius: 10px;
            border: 1px solid rgba(255, 255, 255, 0.16);
            cursor: pointer;
            letter-spacing: 0.02em;
            transition: background 0.2s, border-color 0.2s;
            backdrop-filter: blur(8px);
        }

        .btn-secondary:hover {
            background: rgba(255, 255, 255, 0.1);
            border-color: rgba(126, 200, 216, 0.4);
        }

        /* Trust pills */
        .trust-pills {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
        }

        .trust-pill {
            display: flex;
            align-items: center;
            gap: 6px;
            background: rgba(255, 255, 255, 0.04);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 20px;
            padding: 5px 13px;
            font-size: 11px;
            color: rgba(255, 255, 255, 0.5);
            transition: border-color 0.2s, color 0.2s, background 0.2s;
            backdrop-filter: blur(6px);
        }

        .trust-pill:hover {
            border-color: rgba(126, 200, 216, 0.4);
            color: var(--teal-light);
            background: rgba(30, 122, 138, 0.1);
        }

        /* ── RIGHT PANEL — floating visual cards ──────────────────── */
        .hero-right {
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 480px;
        }

        /* Proof card stack container */
        .hero-proof-stack {
            position: relative;
            width: 320px;
        }

        /* Individual floating card */
        .hf-card {
            background: rgba(6, 22, 34, 0.75);
            backdrop-filter: blur(18px);
            -webkit-backdrop-filter: blur(18px);
            border: 1px solid rgba(126, 200, 216, 0.22);
            border-radius: 18px;
            padding: 20px 22px;
            transition: transform 0.35s ease, box-shadow 0.35s ease;
        }

        .hf-card:hover {
            transform: translateY(-5px) scale(1.02);
            box-shadow: 0 24px 56px rgba(0, 0, 0, 0.5);
        }

        /* Card 1 — Doctor */
        .hf-card-doc {
            position: relative;
            z-index: 3;
            display: flex;
            gap: 14px;
            align-items: center;
            animation: cardFloat 7s ease-in-out infinite;
        }

        /* Card 2 — Stats */
        .hf-card-stats {
            margin-top: 16px;
            position: relative;
            z-index: 2;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1px;
            background: rgba(126, 200, 216, 0.12);
            border-radius: 18px;
            overflow: hidden;
            animation: cardFloat 9s ease-in-out infinite reverse;
        }

        .hf-stat-cell {
            padding: 18px 16px;
            background: rgba(6, 22, 34, 0.82);
            backdrop-filter: blur(18px);
            text-align: center;
        }

        .hf-stat-cell:hover {
            background: rgba(30, 122, 138, 0.12);
        }

        /* Card 3 — Review snippet */
        .hf-card-review {
            margin-top: 16px;
            position: relative;
            z-index: 1;
            animation: cardFloat 8s ease-in-out 2s infinite;
        }

        /* Card badge for right panel */
        .hf-badge {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            background: rgba(30, 122, 138, 0.22);
            border: 1px solid rgba(126, 200, 216, 0.35);
            border-radius: 20px;
            padding: 3px 10px;
            font-size: 10px;
            font-weight: 700;
            color: var(--teal-light);
            letter-spacing: 0.06em;
            text-transform: uppercase;
            margin-bottom: 10px;
        }

        .hf-badge::before {
            content: '';
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: var(--teal-light);
            display: block;
        }

        /* Doctor avatar */
        .doc-avatar {
            width: 52px;
            height: 52px;
            border-radius: 50%;
            background: linear-gradient(135deg, rgba(30, 122, 138, 0.5), rgba(7, 30, 41, 0.9));
            border: 2px solid rgba(126, 200, 216, 0.4);
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            overflow: hidden;
        }

        .doc-avatar svg {
            width: 26px;
            height: 26px;
            stroke: var(--teal-light);
            stroke-width: 1.5;
            fill: none;
        }

        .doc-name {
            font-size: 13.5px;
            font-weight: 700;
            color: #fff;
            line-height: 1.2;
        }

        .doc-title {
            font-size: 11px;
            color: rgba(255, 255, 255, 0.45);
            margin-top: 2px;
        }

        .doc-badge {
            margin-top: 5px;
            font-size: 10px;
            font-weight: 700;
            color: var(--teal-light);
            letter-spacing: 0.04em;
            text-transform: uppercase;
        }

        .stat-big {
            font-family: 'Noto Serif', serif;
            font-size: 30px;
            font-weight: 700;
            color: #fff;
            line-height: 1;
        }

        .stat-big span {
            color: var(--teal-light);
        }

        .stat-desc {
            font-size: 11px;
            color: rgba(255, 255, 255, 0.42);
            margin-top: 4px;
            letter-spacing: 0.02em;
        }

        .stars-row {
            display: flex;
            gap: 2px;
            margin-bottom: 8px;
        }

        .stars-row .star {
            color: var(--gold);
            font-size: 14px;
        }

        .review-quote {
            font-size: 12.5px;
            color: rgba(255, 255, 255, 0.7);
            line-height: 1.55;
            font-style: italic;
        }

        .review-author {
            font-size: 11px;
            font-weight: 700;
            color: var(--teal-light);
            margin-top: 10px;
